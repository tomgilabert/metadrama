---
import Nav from "./Nav.astro";
const { currentPath = "/", isFrontPage = false } = Astro.props;
const headerClass = isFrontPage ? "custom-header front-page-header" : "custom-header";
const navClass = isFrontPage ? "navigation-top front-page-nav" : "navigation-top";
---

<header class="site-header">
  <div class={headerClass}>
    <div class="custom-header-media">
      <img src="/uploads/0208_telonegro.webp" alt="" fetchpriority="high" />
    </div>
    <div class="site-branding">
      <a href="/" class="custom-logo-link" aria-label="METADRAMA - Inicio">
        <img
          src="/uploads/1584_cropped-cropped-imagen5-1-png.png"
          alt="METADRAMA"
          class="custom-logo"
          width="140"
          height="140"
        />
      </a>
      <h1 class="site-title"><a href="/">METADRAMA</a></h1>
    </div>
  </div>
</header>
<div class={navClass}>
  <div class="wrap">
    <Nav currentPath={currentPath} />
    {isFrontPage && (
      <a href="#content" class="menu-scroll-down" aria-label="Desplazarse al contenido">
        <svg class="icon icon-arrow-right" viewBox="0 0 43 32" width="18" height="18" fill="currentColor" aria-hidden="true" style="transform: rotate(90deg);">
          <path d="M0.356 17.956c0.178 0.178 0.533 0.356 0.711 0.356h33.778l-10.311 10.489c-0.178 0.178-0.356 0.533-0.356 0.711 0 0.356 0.178 0.533 0.356 0.711l1.6 1.6c0.178 0.178 0.533 0.356 0.711 0.356s0.533-0.178 0.711-0.356l14.756-14.933c0.178-0.356 0.356-0.711 0.356-0.889s-0.178-0.533-0.356-0.711l-14.756-14.933c0-0.178-0.356-0.356-0.533-0.356s-0.533 0.178-0.711 0.356l-1.6 1.6c-0.178 0.178-0.356 0.533-0.356 0.711s0.178 0.533 0.356 0.711l10.311 10.489h-33.778c-0.178 0-0.533 0.178-0.711 0.356-0.356 0.178-0.533 0.356-0.533 0.711v2.311c0 0.178 0.178 0.533 0.356 0.711z"></path>
        </svg>
      </a>
    )}
  </div>
</div>

{isFrontPage && (
  <script>
    (function() {
      const nav = document.querySelector('.navigation-top') as HTMLElement | null;
      const header = document.querySelector('.custom-header') as HTMLElement | null;
      const scrollDown = document.querySelector('.menu-scroll-down') as HTMLElement | null;
      if (!nav || !header) return;

      function onScroll() {
        if (!nav || !header) return;
        var scrolled = window.scrollY;
        var headerHeight = header.offsetHeight;

        // Nav: fixed cuando pasamos el header
        if (scrolled >= headerHeight - 1) {
          nav.classList.add('site-navigation-fixed');
          if (scrollDown) scrollDown.style.display = 'none';
        } else {
          nav.classList.remove('site-navigation-fixed');
          if (scrollDown) scrollDown.style.display = '';
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      if (scrollDown) {
        scrollDown.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById('content');
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      }
    })();
  </script>
)}
