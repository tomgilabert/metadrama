---
import Nav from "./Nav.astro";
const { currentPath = "/", isFrontPage = false } = Astro.props;
const headerClass = isFrontPage ? "custom-header front-page-header" : "custom-header";
const navClass = isFrontPage ? "navigation-top front-page-nav" : "navigation-top";
---

<header class="site-header">
  <div class={headerClass}>
    <div class="custom-header-media">
      <img src="/uploads/0208_telonegro.webp" alt="" fetchpriority="high" />
    </div>
    <div class="site-branding">
      <a href="/" class="custom-logo-link" aria-label="METADRAMA - Inicio">
        <img
          src="/uploads/1584_cropped-cropped-imagen5-1-png.png"
          alt="METADRAMA"
          class="custom-logo"
          width="140"
          height="140"
        />
      </a>
      <h1 class="site-title"><a href="/">METADRAMA</a></h1>
    </div>
  </div>
  <div class={navClass}>
    <div class="wrap">
      <Nav currentPath={currentPath} />
      {isFrontPage && (
        <a href="#content" class="menu-scroll-down" aria-label="Bajar al contenido">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true" style="transform: rotate(90deg);">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</header>

{isFrontPage && (
  <script>
    (function() {
      var nav = document.querySelector('.navigation-top');
      var header = document.querySelector('.custom-header');
      var scrollDown = document.querySelector('.menu-scroll-down');
      var img = header && header.querySelector('.custom-header-media img');
      if (!nav || !header) return;

      function onScroll() {
        var scrolled = window.scrollY;
        var headerHeight = header.offsetHeight;

        // Nav: fixed cuando pasamos el header
        if (scrolled >= headerHeight - 1) {
          nav.classList.add('site-navigation-fixed');
          if (scrollDown) scrollDown.style.display = 'none';
        } else {
          nav.classList.remove('site-navigation-fixed');
          if (scrollDown) scrollDown.style.display = '';
        }

        // Parallax: la imagen se mueve hacia abajo a 0.4x la velocidad del scroll.
        // Como el header sube a 1x pero la imagen solo baja a 0.4x, el efecto
        // es que el telón se levanta revelando el contenido desde abajo.
        if (img && scrolled < headerHeight) {
          img.style.transform = 'translateY(' + (scrolled * 0.4) + 'px)';
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      if (scrollDown) {
        scrollDown.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById('content');
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      }
    })();
  </script>
)}
