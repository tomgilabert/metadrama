{
  "name": "metadrama",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Sitio de METADRAMA (Universidad de Barcelona) migrado de WordPress a Astro + Decap CMS.",
  "scripts": {
    "dev": "astro dev",
    "dev:cms": "concurrently -n \"astro,cms\" -c \"#61dafb,#ffa500\" \"astro dev\" \"decap-server\"",
    "build": "astro build && node scripts/optimize-images.mjs",
    "build:images": "node scripts/optimize-images.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^4.16.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "concurrently": "^9.1.0",
    "decap-server": "^3.1.0",
    "sharp": "^0.35.2",
    "typescript": "^5.7.3"
  }
}
